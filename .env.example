# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App URL — used for absolute redirects and emails
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Notification providers (server-side only — never NEXT_PUBLIC_) ─────────────
# Email: Resend (https://resend.com) — uncomment when ready
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SMS — Senegalese market options (uncomment the one you use):
# Infobip (international SMS gateway)
# INFOBIP_API_KEY=your-infobip-api-key
# INFOBIP_BASE_URL=https://your-instance.api.infobip.com

# Orange Sénégal SMS API
# ORANGE_SMS_API_KEY=your-orange-sms-api-key

# ── Payment webhooks (server-side only) ────────────────────────────────────────
# HMAC-SHA256 secret for verifying incoming payment webhook signatures.
# Set this in production before enabling any payment provider.
# PAYMENT_WEBHOOK_SECRET=your-webhook-secret

# Wave Sénégal (https://wave.com/developers) — uncomment when ready
# WAVE_API_KEY=your-wave-api-key
# WAVE_WEBHOOK_SECRET=your-wave-webhook-secret

# Orange Money Sénégal — uncomment when ready
# ORANGE_MONEY_CLIENT_ID=your-orange-money-client-id
# ORANGE_MONEY_CLIENT_SECRET=your-orange-money-client-secret
